# Environment variables untuk Railway
# Set ini di Railway Dashboard > Variables

# Port (Railway otomatis set)
# PORT=3000

# Target website
ORIGINAL_HOST=doujindesu.tv

# Nama mirror kamu (PENTING: ganti ini agar unik!)
SITE_NAME=Komikindo Mirror
SITE_TAGLINE=Baca Manga dan Doujin Bahasa Indonesia

# Admin key untuk clear cache (ganti dengan key rahasia)
ADMIN_KEY=changeme

# Chrome path (sudah di-set di Dockerfile, tidak perlu diubah)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
